// csm_synthesize_protocol: fold a work-item tree into a typed GlobalType. A leaf ‚Üí
// request/response interaction; an interior item ‚Üí nested GlobalBox (sequenced via the
// `then` monoid); an iterate-until-pass loop ‚Üí Rec/Var + Critic-gated Choice.
// Palette: tree=amber, leaf‚Üíinteraction=emerald, interior‚Üíbox=violet, loop‚Üícritic=gold.
digraph fold {
  rankdir=LR;
  bgcolor="transparent";
  node [shape=box, style="filled,rounded", fontname="Inter", fontsize=10];
  edge [color="#475569", arrowsize=0.6];

  subgraph cluster_tree {
    label="plan = work-item tree (pgmcp)"; fontname="Inter"; fontsize=12;
    color="#b45309"; style="rounded"; bgcolor="#fffbeb";
    node [color="#b45309", fillcolor="#fef3c7", fontcolor="#7c2d12"];
    root [label="plan (root)"];
    phase [label="epic / interior task\n(has children)"];
    t1 [label="leaf task t‚āĀ"];
    t2 [label="leaf task t‚āā"];
    loop [label="iterate-until-pass task"];
    root -> phase; phase -> t1; phase -> t2; root -> loop;
  }

  fold [label="csm_synthesize_protocol\n(hierarchy-preserving fold,\nsequenced by GlobalType::then)", shape=box3d, color="#312e81", fillcolor="#c7d2fe", fontcolor="#1e1b4b"];

  subgraph cluster_g {
    label="GlobalType G (validated: well_formed ‚ąß media_ok ‚ąß projects ‚ąÄrole)"; fontname="Inter"; fontsize=12;
    color="#3730a3"; style="rounded"; bgcolor="#eef2ff";
    i1 [label="O‚ÜíW‚āĀ:t‚āĀ_req . W‚āĀ‚ÜíO:t‚āĀ_done", color="#047857", fillcolor="#d1fae5", fontcolor="#065f46"];
    box [label="GlobalBox‚ü®enter‚ü©{ ‚Ä¶ }‚ü®exit‚ü©\n(interior ‚Üí composite state, push/pop)", color="#6d28d9", fillcolor="#ede9fe", fontcolor="#4c1d95"];
    crit [label="őľL. ‚Ä¶ C‚ÜíO{ pass:end ; fail:L }\n(Critic owns the gating Choice)", color="#a16207", fillcolor="#fef9c3", fontcolor="#713f12"];
  }

  root -> fold [style=bold, color="#b45309"];
  loop -> fold [style=bold, color="#b45309"];
  fold -> i1; fold -> box; fold -> crit;

  drive [label="client-drivable plan\n[{peer, request, response}‚Ä¶]", shape=note, color="#15803d", fillcolor="#dcfce7", fontcolor="#14532d"];
  i1 -> drive [style=dotted]; box -> drive [style=dotted]; crit -> drive [style=dotted];
}
