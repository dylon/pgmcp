/target/
/.fastembed_cache/
**/.fastembed_cache/
/.claude/
*.cache
*.log

# Node tooling. The diagramming-catalog npm tools (vega-cli, mscgenjs,
# bytefield-svg, wavedrom-cli, dbml-renderer) live in the workspace-parent
# node_modules, not here — this guards against a stray `npm install` in the
# crate root polluting the repo.
node_modules/
package-lock.json
!webui/package-lock.json
webui/.shadow-cljs/
webui/resources/cljs/

# Rocq compilation artifacts (P13.5). The proof source
# (`docs/formal/rocq/*.v`) is committed; `coqc` outputs (`*.vo`,
# `*.vos`, `*.vok`, `*.glob`, `.*.aux`) are reproducible from
# source and are produced by the verify.sh advisory gate.
docs/formal/rocq/*.vo
docs/formal/rocq/*.vos
docs/formal/rocq/*.vok
docs/formal/rocq/*.glob
docs/formal/rocq/.*.aux
docs/formal/tla/states/
docs/formal/states/
# TLAPS (`tlapm`) proof cache + fingerprints, and stray TLC/Coq aux files —
# all reproducible from the committed `.tla`/`.v` sources by the verify.sh
# advisory Formal gate (and ad-hoc `tlapm`/`tlc`/`coqc` runs).
docs/formal/**/.tlacache/
docs/formal/**/*.thy
docs/formal/**/.*.aux

.pgmcp.toml

# Python bytecode cache (scripts/*.py — e.g. the webui render smoke test)
__pycache__/
*.pyc
